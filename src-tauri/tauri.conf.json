{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalFiles",
  "version": "0.1.0",
  "identifier": "com.localfiles.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1458",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "LocalFiles",
        "width": 1200,
        "height": 780,
        "minWidth": 800,
        "minHeight": 540,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
